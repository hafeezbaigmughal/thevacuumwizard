{% if section.settings.text != blank or section.blocks.size > 0 or section.settings.link != blank or request.design_mode %}<section class="testimonial">
  <div class="wrapper">
    <h2 class="title_center1"><span>{{ section.settings.heading }}</span></h2>
    {% if section.settings.text != blank %}<div class="testimonial_global"><div class="review-box rte">{{ section.settings.text }}</div></div>{% endif %}
    {% for block in section.blocks %}<div class="review-app-block" {{ block.shopify_attributes }}>{% render block %}</div>{% endfor %}
    {% if section.settings.link != blank %}<a class="rd_more btn3" href="{{ section.settings.link }}">{{ section.settings.link_label }}</a>{% endif %}
  </div>
</section>{% endif %}
{% schema %}
{
  "name": "Home reviews",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Latest Reviews" },
    { "type": "richtext", "id": "text", "label": "Review summary", "info": "Use an app block below for live review widgets." },
    { "type": "text", "id": "link_label", "label": "Button label", "default": "View more" },
    { "type": "url", "id": "link", "label": "Button link" }
  ],
  "blocks": [{ "type": "@app" }],
  "presets": [{ "name": "Home reviews" }]
}
{% endschema %}
