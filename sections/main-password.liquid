<section class="password-page">
  <div class="password-page__inner">
    {% if section.settings.logo != blank %}
      {{ section.settings.logo | image_url: width: 320 | image_tag: loading: 'eager', alt: shop.name }}
    {% else %}
      <img src="{{ 'home-vacuum-logo.png' | asset_url }}" alt="{{ shop.name | escape }}" width="212" height="107">
    {% endif %}
    <h1>{{ section.settings.heading }}</h1>
    {% if shop.password_message != blank %}<p>{{ shop.password_message }}</p>{% endif %}
    {% form 'storefront_password', class: 'password-form' %}
      {{ form.errors | default_errors }}
      <label for="StorefrontPassword">Store password</label>
      <input id="StorefrontPassword" type="password" name="password" autocomplete="current-password" required>
      <button class="button button--red" type="submit">Enter store</button>
    {% endform %}
  </div>
</section>
{% schema %}
{
  "name": "Password page",
  "settings": [
    { "type": "image_picker", "id": "logo", "label": "Logo" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Opening soon" }
  ]
}
{% endschema %}
