{%- liquid
  assign current_variant = product.selected_or_first_available_variant
  assign product_alt = product.featured_image.alt | default: product.title
  assign related_collection = product.collections.first
-%}

<div class="innerBanner product-detail-banner">
  {% if section.settings.banner_image != blank %}
    {{ section.settings.banner_image | image_url: width: 2100 | image_tag: loading: 'eager', alt: 'Product Details' }}
  {% else %}
    <img src="{{ 'product-banner.png' | asset_url }}" width="1920" height="320" alt="Product Details" loading="eager">
  {% endif %}
  <div class="banrcaptionBox">
    <div class="wrapper">
      <h2 class="title_center1"><span>Product <strong>Details</strong></span></h2>
    </div>
  </div>
</div>

<section class="our_product_inr productinnerpage">
  <div class="wrapper">
    <div class="our_product_details">
      <div class="product-detail" data-section-id="{{ section.id }}">
  <div class="product-detail__top">
    <div class="product-detail__gallery">
      <div class="product-detail__main-image">
        {% if product.featured_image %}
          {{ product.featured_image | image_url: width: 1000 | image_tag: loading: 'eager', alt: product_alt, id: 'ProductMainImage' }}
        {% else %}
          {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
        {% endif %}
      </div>

      {% if product.images.size > 1 %}
        <div class="product-detail__thumbs" aria-label="Product images">
          {% for image in product.images %}
            {% assign thumb_alt = image.alt | default: product.title %}
            <button class="product-detail__thumb{% if forloop.first %} is-active{% endif %}" type="button" data-product-thumb="{{ image | image_url: width: 1000 }}" aria-label="Show image {{ forloop.index }}">
              {{ image | image_url: width: 180 | image_tag: loading: 'lazy', alt: thumb_alt }}
            </button>
          {% endfor %}
        </div>
      {% endif %}
    </div>

    <div class="product-detail__summary">
      <h1>{{ product.title }}</h1>

      <div class="product-detail__price" data-product-price>
        {{ current_variant.price | money }}
        <s data-product-compare-price {% unless current_variant.compare_at_price > current_variant.price %}hidden{% endunless %}>{% if current_variant.compare_at_price > current_variant.price %}{{ current_variant.compare_at_price | money }}{% endif %}</s>
        <small>Including VAT</small>
      </div>

      {% if section.settings.show_short_description %}
        <div class="product-detail__short rte">
          {% if product.metafields.custom.short_description != blank %}
            {{ product.metafields.custom.short_description | metafield_tag }}
          {% else %}
            <p>{{ product.description | strip_html | truncatewords: section.settings.short_description_words }}</p>
          {% endif %}
        </div>
      {% endif %}

      <p class="product-detail__stock{% unless current_variant.available %} is-out{% endunless %}" data-product-stock>
        {% if current_variant.available %}
          In stock
        {% else %}
          Out of stock
        {% endif %}
      </p>

      {% form 'product', product, class: 'product-detail__form' %}
        {% unless product.has_only_default_variant %}
          <div class="product-detail__options">
            {% for option in product.options_with_values %}
              <label for="ProductOption-{{ section.id }}-{{ forloop.index0 }}">{{ option.name }}</label>
              <select id="ProductOption-{{ section.id }}-{{ forloop.index0 }}" data-product-option="{{ forloop.index0 }}">
                {% for value in option.values %}
                  <option value="{{ value | escape }}" {% if option.selected_value == value %}selected{% endif %}>{{ value }}</option>
                {% endfor %}
              </select>
            {% endfor %}
          </div>

          <label class="product-detail__variant-label" for="ProductVariant-{{ section.id }}">Variant</label>
          <select id="ProductVariant-{{ section.id }}" name="id" data-product-variant-select>
            {% for variant in product.variants %}
              <option
                value="{{ variant.id }}"
                data-price="{{ variant.price | money }}"
                data-compare-price="{% if variant.compare_at_price > variant.price %}{{ variant.compare_at_price | money }}{% endif %}"
                data-available="{{ variant.available }}"
                data-sku="{{ variant.sku | escape }}"
                data-options="{{ variant.options | join: '||' | escape }}"
                data-image="{% if variant.featured_image %}{{ variant.featured_image | image_url: width: 1000 }}{% endif %}"
                {% if variant == current_variant %}selected{% endif %}
                {% unless variant.available %}disabled{% endunless %}
              >
                {{ variant.title }} - {{ variant.price | money }}{% unless variant.available %} - Sold out{% endunless %}
              </option>
            {% endfor %}
          </select>
        {% else %}
          <input type="hidden" name="id" value="{{ current_variant.id }}">
        {% endunless %}

        <div class="product-detail__buy-row">
          <label for="Quantity-{{ section.id }}">Quantity</label>
          <input id="Quantity-{{ section.id }}" type="number" name="quantity" value="1" min="1" inputmode="numeric">
          <button class="button button--red product-detail__submit" type="submit" {% unless current_variant.available %}disabled{% endunless %} data-product-submit>
            {% if current_variant.available %}Add to Cart{% else %}Sold Out{% endif %}
          </button>
        </div>

        {% if section.settings.show_dynamic_checkout %}
          <div class="product-detail__payment">
            {{ form | payment_button }}
          </div>
        {% endif %}
      {% endform %}

      {% if section.settings.wishlist_page != blank %}
        <a class="product-detail__wishlist" href="{{ section.settings.wishlist_page.url }}">Add to Wishlist</a>
      {% endif %}

      <div class="product-detail__meta">
        {% if current_variant.sku != blank %}
          <p><strong>SKU:</strong> <span data-product-sku>{{ current_variant.sku }}</span></p>
        {% endif %}
        {% if product.vendor != blank %}
          <p><strong>Brand:</strong> {{ product.vendor }}</p>
        {% endif %}
        {% if product.type != blank %}
          <p><strong>Type:</strong> {{ product.type }}</p>
        {% endif %}
        {% if product.collections.size > 0 %}
          <p><strong>Categories:</strong>
            {% for collection in product.collections limit: 5 %}
              <a href="{{ collection.url }}">{{ collection.title }}</a>{% unless forloop.last %}, {% endunless %}
            {% endfor %}
          </p>
        {% endif %}
      </div>
    </div>
  </div>

  <div class="product-tabs" data-product-tabs>
    <div class="product-tabs__nav" role="tablist">
      <button class="is-active" type="button" role="tab" aria-selected="true" data-product-tab-button="description">Description</button>
      <button type="button" role="tab" aria-selected="false" data-product-tab-button="additional">Additional information</button>
    </div>

    <div class="product-tabs__panel rte is-active" role="tabpanel" data-product-tab-panel="description">
      <h2>Description</h2>
        {% if product.description != blank %}{{ product.description }}{% else %}<p>No description is available for this product.</p>{% endif %}
    </div>

    <div class="product-tabs__panel" role="tabpanel" data-product-tab-panel="additional">
      <h2>Additional information</h2>
      <table class="product-detail__table">
        <tbody>
          {% if current_variant.weight > 0 %}
            <tr>
              <th scope="row">Weight</th>
              <td>{{ current_variant.weight | weight_with_unit }}</td>
            </tr>
          {% endif %}
          {% if current_variant.sku != blank %}
            <tr>
              <th scope="row">SKU</th>
              <td>{{ current_variant.sku }}</td>
            </tr>
          {% endif %}
          {% for option in product.options_with_values %}
            <tr>
              <th scope="row">{{ option.name }}</th>
              <td>{{ option.values | join: ', ' }}</td>
            </tr>
          {% endfor %}
          {% if product.tags.size > 0 %}
            <tr>
              <th scope="row">Tags</th>
              <td>{{ product.tags | join: ', ' }}</td>
            </tr>
          {% endif %}
        </tbody>
      </table>
    </div>

  </div>

  {% for block in section.blocks %}
    <div class="product-app-block" {{ block.shopify_attributes }}>{% render block %}</div>
  {% endfor %}

  {% if section.settings.show_related_products and related_collection != blank %}
    <section class="product-related">
      <h2>Related products</h2>
      <div class="cat_sec productsBox clear">
        <ul class="products_lists product-grid product-grid--related">
        {% assign shown_related = 0 %}
        {% for related_product in related_collection.products limit: 8 %}
          {% unless related_product.id == product.id %}
            <li>
              <div class="our_product_details_pic">
                <a href="{{ related_product.url }}" class="pic_link" aria-label="{{ related_product.title | escape }}">
                  {% if related_product.featured_image %}
                    {{ related_product.featured_image | image_url: width: 520 | image_tag: loading: 'lazy', alt: related_product.title }}
                  {% else %}
                    {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
                  {% endif %}
                </a>
                <div class="over_lay">
                  <a class="button" href="{{ related_product.url }}">View Product</a>
                </div>
              </div>

              <div class="our_product_details_text">
                <div class="book_name">
                  <a href="{{ related_product.url }}">{{ related_product.title }}</a>
                </div>
                <h3 class="prize">
                  {% if related_product.compare_at_price > related_product.price %}
                    {{ related_product.price | money }}
                    <span>{{ related_product.compare_at_price | money }}</span>
                  {% else %}
                    {{ related_product.price | money }}
                  {% endif %}
                </h3>
                <div class="add_waslist">
                  {% if related_product.available and related_product.has_only_default_variant %}
                    <form method="post" action="{{ routes.cart_add_url }}">
                      <input type="hidden" name="id" value="{{ related_product.selected_or_first_available_variant.id }}">
                      <button type="submit" aria-label="Add {{ related_product.title | escape }} to cart">
                        <svg viewBox="0 0 24 24" aria-hidden="true">
                          <path d="M7 18c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2Zm10 0c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2ZM6.2 6l.9 5.3c.2 1 1 1.7 2 1.7h7.4c.9 0 1.7-.6 1.9-1.5L20 6H6.2ZM5.8 4H21c.6 0 1 .5.9 1.1l-1.6 6.9c-.4 1.8-2 3-3.8 3H9.1c-2 0-3.6-1.4-4-3.3L3.9 4.9 2 4.5V3h2.6c.6 0 1.1.4 1.2 1Z"/>
                        </svg>
                      </button>
                    </form>
                  {% else %}
                    <a href="{{ related_product.url }}" aria-label="{% if related_product.available %}Choose options for{% else %}View{% endif %} {{ related_product.title | escape }}">
                      <svg viewBox="0 0 24 24" aria-hidden="true">
                        <path d="M7 18c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2Zm10 0c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2ZM6.2 6l.9 5.3c.2 1 1 1.7 2 1.7h7.4c.9 0 1.7-.6 1.9-1.5L20 6H6.2ZM5.8 4H21c.6 0 1 .5.9 1.1l-1.6 6.9c-.4 1.8-2 3-3.8 3H9.1c-2 0-3.6-1.4-4-3.3L3.9 4.9 2 4.5V3h2.6c.6 0 1.1.4 1.2 1Z"/>
                      </svg>
                    </a>
                  {% endif %}
                </div>
              </div>
            </li>
            {% assign shown_related = shown_related | plus: 1 %}
          {% endunless %}
          {% if shown_related >= section.settings.related_limit %}
            {% break %}
          {% endif %}
        {% endfor %}
        </ul>
      </div>
    </section>
  {% endif %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Main product",
  "settings": [
    {
      "type": "image_picker",
      "id": "banner_image",
      "label": "Banner image"
    },
    {
      "type": "checkbox",
      "id": "show_short_description",
      "label": "Show short description",
      "default": true
    },
    {
      "type": "range",
      "id": "short_description_words",
      "label": "Short description words",
      "min": 20,
      "max": 120,
      "step": 5,
      "default": 45
    },
    {
      "type": "checkbox",
      "id": "show_dynamic_checkout",
      "label": "Show dynamic checkout button",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_related_products",
      "label": "Show related products",
      "default": true
    },
    {
      "type": "range",
      "id": "related_limit",
      "label": "Related products to show",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 4
    },
    {
      "type": "page",
      "id": "wishlist_page",
      "label": "Wishlist page",
      "info": "Leave blank unless a wishlist app or page is configured."
    }
  ],
  "blocks": [
    {
      "type": "@app"
    }
  ]
}
{% endschema %}
