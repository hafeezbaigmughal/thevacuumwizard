<section class="blogs">
  <div class="wrapper">
    <h2 class="title_center1"><span>{{ section.settings.heading }}</span></h2>
    <ul>
      {% if section.settings.blog != blank %}
        {% for article in section.settings.blog.articles limit: section.settings.articles_to_show %}
          <li>
            <div class="blog-item">
              <a href="{{ article.url }}"><div class="blog_pic">{% if article.image %}{{ article.image | image_url: width: 1024 | image_tag: loading: 'lazy', widths: '360, 540, 720, 1024', sizes: '(max-width: 640px) 100vw, 360px', alt: article.image.alt | default: article.title }}{% else %}{{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}{% endif %}</div></a>
              <div class="blog_text">
                <time datetime="{{ article.published_at | date: '%Y-%m-%d' }}">{{ article.published_at | date: '%d %b %Y' }}</time>
                <h3><a href="{{ article.url }}">{{ article.title }}</a></h3>
                <p>{{ article.excerpt_or_content | strip_html | truncate: section.settings.excerpt_length }}</p>
                <a href="{{ article.url }}" class="rd_more">{{ section.settings.read_more_label }}</a>
              </div>
            </div>
          </li>
        {% endfor %}
      {% elsif request.design_mode %}
        <li class="noproductincategory">Choose a blog in this section's settings.</li>
      {% endif %}
    </ul>
    {% if section.settings.blog != blank and section.settings.show_view_all %}<a class="rd_more btn3" href="{{ section.settings.blog.url }}">{{ section.settings.view_all_label }}</a>{% endif %}
  </div>
</section>
{% schema %}
{
  "name": "Home blog",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Blogs" },
    { "type": "blog", "id": "blog", "label": "Blog" },
    { "type": "range", "id": "articles_to_show", "label": "Articles to show", "min": 1, "max": 6, "step": 1, "default": 3 },
    { "type": "range", "id": "excerpt_length", "label": "Excerpt length", "min": 80, "max": 240, "step": 10, "default": 150 },
    { "type": "text", "id": "read_more_label", "label": "Read more label", "default": "Read more..." },
    { "type": "checkbox", "id": "show_view_all", "label": "Show view all button", "default": true },
    { "type": "text", "id": "view_all_label", "label": "View all label", "default": "View more" }
  ],
  "presets": [{ "name": "Home blog" }]
}
{% endschema %}
