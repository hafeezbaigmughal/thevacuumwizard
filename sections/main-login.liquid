<section class="page-width template-section account-form">
  <h1>Log in</h1>
  {% form 'customer_login' %}
    {{ form.errors | default_errors }}
    <label for="CustomerEmail">Email</label>
    <input id="CustomerEmail" type="email" name="customer[email]" autocomplete="email">
    <label for="CustomerPassword">Password</label>
    <input id="CustomerPassword" type="password" name="customer[password]" autocomplete="current-password">
    <button class="button button--red" type="submit">Log in</button>
    <a class="text-link" href="{{ routes.account_register_url }}">Create account</a>
  {% endform %}

  <details class="recover-password">
    <summary>Forgot your password?</summary>
    {% form 'recover_customer_password' %}
      {% if form.posted_successfully? %}<p class="form-status">We have sent you an email with a password reset link.</p>{% endif %}
      {{ form.errors | default_errors }}
      <label for="RecoverEmail">Email</label>
      <input id="RecoverEmail" type="email" name="email" autocomplete="email" required>
      <button class="button button--red" type="submit">Submit</button>
    {% endform %}
  </details>
</section>

{% schema %}
{
  "name": "Customer login"
}
{% endschema %}
