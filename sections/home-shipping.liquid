<section class="free_next_day">
  <div class="wrapper">
    <div class="free_next_dayBox">
      {% if section.settings.image != blank %}
        {{ section.settings.image | image_url: width: 500 | image_tag: loading: 'lazy', alt: section.settings.image.alt | default: section.settings.heading }}
      {% else %}
        <img src="{{ 'home-shipping-box.png' | asset_url }}" alt="" loading="lazy" width="242" height="290">
      {% endif %}
    </div>
    <div class="free_next_dayText">
      <h2>{{ section.settings.heading }}</h2>
      <ul>
        {% if section.settings.primary_link != blank %}<li><a href="{{ section.settings.primary_link }}" class="btn2">{{ section.settings.primary_label }}</a></li>{% endif %}
        {% if section.settings.secondary_link != blank %}<li><a href="{{ section.settings.secondary_link }}" class="btn2">{{ section.settings.secondary_label }}</a></li>{% endif %}
      </ul>
    </div>
  </div>
</section>
{% schema %}
{
  "name": "Home shipping banner",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Next Working Day Shipping On All Orders Only GBP 4.99" },
    { "type": "text", "id": "primary_label", "label": "Primary button label", "default": "Shop now" },
    { "type": "url", "id": "primary_link", "label": "Primary button link" },
    { "type": "text", "id": "secondary_label", "label": "Secondary button label", "default": "Contact us" },
    { "type": "url", "id": "secondary_link", "label": "Secondary button link" }
  ],
  "presets": [{ "name": "Home shipping banner" }]
}
{% endschema %}
