{%- liquid
  assign shop_link = section.settings.shop_link | default: routes.all_products_collection_url
  assign contact_link = section.settings.contact_link | default: '/pages/contact'
  assign about_link = section.settings.about_link | default: '/pages/about-us'
  assign reviews_link = section.settings.reviews_link | default: '/pages/reviews'

  assign best_sellers_collection = section.settings.best_sellers_collection
  if best_sellers_collection == blank
    assign best_sellers_collection = collections['best-sellers']
  endif
  if best_sellers_collection == blank
    assign best_sellers_collection = collections['frontpage']
  endif
  if best_sellers_collection == blank
    assign best_sellers_collection = collections['all']
  endif

  assign featured_collection = section.settings.featured_collection
  if featured_collection == blank
    assign featured_collection = collections['all']
  endif

  assign latest_collection = section.settings.latest_collection
  if latest_collection == blank
    assign latest_collection = collections['latest-products']
  endif
  if latest_collection == blank
    assign latest_collection = collections['all']
  endif

  assign vacuum_collection = section.settings.vacuum_collection
  if vacuum_collection == blank
    assign vacuum_collection = collections['vacuum-products']
  endif
  if vacuum_collection == blank
    assign vacuum_collection = collections['all']
  endif

  assign related_collection = section.settings.related_collection
  if related_collection == blank
    assign related_collection = best_sellers_collection
  endif

  assign best_sellers_limit = section.settings.best_sellers_limit | default: 6
  assign featured_limit = section.settings.featured_limit | default: 8
  assign latest_limit = section.settings.latest_limit | default: 8
  assign vacuum_limit = section.settings.vacuum_limit | default: 8
  assign related_limit = section.settings.related_limit | default: 4
-%}

<section class="banner_home" aria-label="{{ section.settings.hero_label | escape }}">
  <img class="banner_home_img" src="{{ 'home-hero-bg.webp' | asset_url }}" alt="The Vacuum Wizard" width="1920" height="578">
  <div class="captionBox">
    <div class="wrapper">
      <div class="caption">
        <div class="left-div">
          <h1>The Independent <strong>Dyson Hand Held</strong> <span>Vacuum Specialists</span></h1>
          <ul>
            <li><a href="{{ shop_link }}">shop now</a></li>
            <li><a href="{{ contact_link }}">Call Us Now</a></li>
          </ul>
        </div>
      </div>
      <div class="right-div">
        <ul>
          <li><img src="{{ 'home-hero-part.webp' | asset_url }}" alt="Dyson vacuum part" width="432" height="460"></li>
          <li><img src="{{ 'home-hero-battery.webp' | asset_url }}" alt="Dyson battery" width="225" height="314"></li>
        </ul>
      </div>
    </div>
  </div>
</section>

<section class="modelparts">
  <div class="wrapper">
    <h2 class="title_center2">Choose Your Model Below For Spare Parts <span>Or Complete Machines</span></h2>
    <ul id="modelparts_slider">
      {%- assign model_fallbacks = 'home-dyson-v6.jpg|home-dyson-v7.jpg|home-dyson-v8.jpg|home-dyson-v10.jpg|home-dyson-v11.jpg' | split: '|' -%}
      {%- assign model_index = 0 -%}
      {% for block in section.blocks %}
        {% if block.type == 'model' %}
          {% assign fallback = model_fallbacks[model_index] | default: 'home-dyson-v6.jpg' %}
          <li {{ block.shopify_attributes }}>
            <a href="{{ block.settings.link | default: routes.all_products_collection_url }}">
              <div class="modelparts_pic">
                {% if block.settings.image != blank %}
                  {{ block.settings.image | image_url: width: 292 | image_tag: loading: 'lazy', alt: block.settings.title }}
                {% else %}
                  <img src="{{ fallback | asset_url }}" alt="{{ block.settings.title | escape }}" loading="lazy" width="146" height="148">
                {% endif %}
              </div>
              <div class="modelparts_text"><h3>{{ block.settings.title }}</h3></div>
            </a>
          </li>
          {% assign model_index = model_index | plus: 1 %}
        {% endif %}
      {% endfor %}
    </ul>
  </div>
</section>

<section class="why_choose_us">
  <div class="wrapper">
    <h2 class="title_center1"><span>Why <strong>Choose Us</strong></span></h2>
  </div>
  <div class="why_choose_us_box">
    <div class="wrapper">
      <ul>
        <li>
          <div class="why_choose_us_item">
            <div class="why_choose_us_pic" aria-hidden="true"></div>
            <h3>Express UK Delivery</h3>
            <h4>On all orders only &pound;4.99</h4>
          </div>
        </li>
        <li>
          <div class="why_choose_us_item">
            <div class="why_choose_us_pic" aria-hidden="true"></div>
            <h3>Large stock</h3>
            <h4>of Dyson Hand Held Vacuum Parts</h4>
          </div>
        </li>
        <li>
          <div class="why_choose_us_item">
            <div class="why_choose_us_pic" aria-hidden="true"></div>
            <h3>Next Business Day Delivery</h3>
            <h4>On all UK orders placed before 2pm</h4>
          </div>
        </li>
      </ul>
    </div>
  </div>
</section>

<section class="about_vacuum">
  <div class="wrapper">
    <div class="about_vaccum_text">
      <h2>{{ section.settings.about_heading }}</h2>
      <div class="rte">{{ section.settings.about_text }}</div>
      <a href="{{ about_link }}" class="btn1">About Us</a>
    </div>
    <div class="about_vaccum_pic">
      {% if section.settings.about_image != blank %}
        {{ section.settings.about_image | image_url: width: 720 | image_tag: loading: 'lazy', alt: section.settings.about_heading }}
      {% else %}
        <img src="{{ 'home-about.jpg' | asset_url }}" alt="Dyson vacuum in a home" loading="lazy" width="1594" height="1600">
      {% endif %}
      <div class="about_overlay">
        <div class="about_vaccum_box"><a href="{{ about_link }}" class="btn1">About Us</a></div>
      </div>
    </div>
  </div>
</section>

<section class="best_seller">
  <div class="wrapper">
    <h2 class="title_center1"><span>Best <strong>Sellers</strong></span></h2>
    <div class="best_product_details">
      <ul>
        {% if best_sellers_collection != blank and best_sellers_collection.products.size > 0 %}
          {% for product in best_sellers_collection.products limit: best_sellers_limit %}
            {% render 'vw-home-product-card', product: product, media_class: 'best_product_details_pic', text_class: 'best_product_details_text' %}
          {% endfor %}
        {% else %}
          {% assign best_images = 'home-product-logo.png|home-product-v6-battery.jpg|home-product-v10-vacwiz.jpg|home-product-v10-battery.jpg|home-product-v11-battery.jpg|home-product-v11-battery.jpg' | split: '|' %}
          {% assign best_titles = 'Dyson V15 Detect Total Clean Cordless Vacuum Cleaner|Dyson V6 Genuine Battery Power Pack 967810-21|Dyson V10 VacWiz Battery Power Pack 969352-02|Dyson V10 Genuine Battery Power Pack 969352-02|Dyson VacWiz V11 SV14 Battery Power Pack Replacement 970145-02|Dyson V11 SV14 Genuine Battery Power Pack 970145-02' | split: '|' %}
          {% assign best_prices = '&pound; 499.99|&pound; 64.99|&pound; 52.99|&pound; 89.99|&pound; 58.99|&pound; 89.99' | split: '|' %}
          {% for image in best_images %}
            {% render 'vw-home-product-card', fallback_image: image, fallback_title: best_titles[forloop.index0], fallback_price: best_prices[forloop.index0], media_class: 'best_product_details_pic', text_class: 'best_product_details_text' %}
          {% endfor %}
        {% endif %}
      </ul>
    </div>
  </div>
</section>

<section class="pruduct_category" data-home-product-tabs>
  <div class="wrapper">
    <div id="tabs-containers">
      <ul class="pruduct_category_tabs-menus" role="tablist" aria-label="Homepage product groups">
        <li class="pruduct_category_currents"><button class="tab" type="button" role="tab" aria-selected="true" data-home-product-tab="featured">Featured Products</button></li>
        <li><button class="tab" type="button" role="tab" aria-selected="false" data-home-product-tab="latest">Latest Products</button></li>
        <li><button class="tab" type="button" role="tab" aria-selected="false" data-home-product-tab="vacuum">Vacuum Products</button></li>
      </ul>

      <div class="pruduct_category_tab-contents home-product-tabs__panel is-active" data-home-product-panel="featured">
        <div class="pruduct_category_dtls pruduct_category_tab_dtls_1">
          <ul>
            {% if featured_collection != blank and featured_collection.products.size > 0 %}
              {% for product in featured_collection.products limit: featured_limit %}
                {% render 'vw-home-product-card', product: product, wrapper_class: 'product_element_details', media_class: 'best_product_details_pic', text_class: 'best_product_details_text' %}
              {% endfor %}
            {% else %}
              {% assign tab_images = 'home-product-logo.png|home-product-v10-battery.jpg|home-product-v11-battery.jpg|home-product-charger.jpg' | split: '|' %}
              {% for image in tab_images %}
                {% render 'vw-home-product-card', fallback_image: image, wrapper_class: 'product_element_details', media_class: 'best_product_details_pic', text_class: 'best_product_details_text' %}
              {% endfor %}
            {% endif %}
          </ul>
        </div>
      </div>

      <div class="pruduct_category_tab-contents home-product-tabs__panel" data-home-product-panel="latest">
        <div class="pruduct_category_dtls pruduct_category_tab_dtls_1">
          <ul>
            {% if latest_collection != blank and latest_collection.products.size > 0 %}
              {% for product in latest_collection.products limit: latest_limit %}
                {% render 'vw-home-product-card', product: product, wrapper_class: 'product_element_details', media_class: 'best_product_details_pic', text_class: 'best_product_details_text' %}
              {% endfor %}
            {% else %}
              <p class="noproductincategory">Select a Latest Products collection in the theme editor.</p>
            {% endif %}
          </ul>
        </div>
      </div>

      <div class="pruduct_category_tab-contents home-product-tabs__panel" data-home-product-panel="vacuum">
        <div class="pruduct_category_dtls pruduct_category_tab_dtls_1">
          <ul>
            {% if vacuum_collection != blank and vacuum_collection.products.size > 0 %}
              {% for product in vacuum_collection.products limit: vacuum_limit %}
                {% render 'vw-home-product-card', product: product, wrapper_class: 'product_element_details', media_class: 'best_product_details_pic', text_class: 'best_product_details_text' %}
              {% endfor %}
            {% else %}
              <p class="noproductincategory">Select a Vacuum Products collection in the theme editor.</p>
            {% endif %}
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="free_next_day">
  <div class="wrapper">
    <div class="free_next_dayBox">
      <img src="{{ 'home-shipping-box.png' | asset_url }}" alt="Next Working Day Shipping" loading="lazy" width="242" height="290">
    </div>
    <div class="free_next_dayText">
      <h2>Next Working Day Shipping On All Orders Only &pound;4.99</h2>
      <ul>
        <li><a href="{{ shop_link }}" class="btn2">shop now</a></li>
        <li><a href="{{ contact_link }}" class="btn2">Contact us</a></li>
      </ul>
    </div>
  </div>
</section>

<section class="related_products">
  <div class="wrapper">
    <h2 class="title_center1"><span>Related <strong>Products</strong></span></h2>
    <div class="related_product_details">
      <ul>
        {% if related_collection != blank and related_collection.products.size > 0 %}
          {% for product in related_collection.products limit: related_limit %}
            {% render 'vw-home-product-card', product: product, media_class: 'related_product_details_pic', text_class: 'related_product_details_text' %}
          {% endfor %}
        {% else %}
          {% assign related_images = 'home-product-v10-battery.jpg|home-product-v11-battery.jpg|home-product-v11-battery.jpg|home-product-v11-click-battery.jpg' | split: '|' %}
          {% assign related_titles = 'Dyson V10 Genuine Battery Power Pack 969352-02|Dyson VacWiz V11 SV14 Battery Power Pack Replacement 970145-02|Dyson V11 SV14 Genuine Battery Power Pack 970145-02|Dyson V11 and V15 Click-in Battery 970938-01' | split: '|' %}
          {% assign related_prices = '&pound; 89.99|&pound; 58.99|&pound; 89.99|&pound; 104.99' | split: '|' %}
          {% for image in related_images %}
            {% render 'vw-home-product-card', fallback_image: image, fallback_title: related_titles[forloop.index0], fallback_price: related_prices[forloop.index0], media_class: 'related_product_details_pic', text_class: 'related_product_details_text' %}
          {% endfor %}
        {% endif %}
      </ul>
    </div>
  </div>
</section>

<section class="testimonial">
  <div class="wrapper">
    <h2 class="title_center1"><span>latest Reviews</span></h2>
    <div class="testimonial_global">
      <div class="review-box">
        <strong>Trustindex</strong>
        <p>Trustindex verifies that the original source of the review is Google.</p>
      </div>
    </div>
    <a class="rd_more btn3" href="{{ reviews_link }}">view more</a>
  </div>
</section>

<section class="big_season_sale">
  <div class="wrapper">
    <a href="{{ shop_link }}"><img src="{{ 'home-season-sale.png' | asset_url }}" alt="The Vacuum Wizard sale" loading="lazy" width="876" height="109"></a>
  </div>
</section>

<section class="blogs">
  <div class="wrapper">
    <h2 class="title_center1"><span>Blogs</span></h2>
    <ul>
      {% assign blog_images = 'home-blog-v7-battery.webp|home-blog-v7-troubleshooting.webp|home-blog-v6-battery.webp' | split: '|' %}
      {% assign blog_titles = 'How to Replace Dyson V7 Battery?|Dyson V7 Troubleshooting: Common Issues and Solutions|How to Replace Dyson V6 Battery?' | split: '|' %}
      {% assign blog_dates = '03 Jan 2025|12 Oct 2024|07 Sep 2024' | split: '|' %}
      {% assign selected_blog = section.settings.blog %}
      {% for article in selected_blog.articles limit: 3 %}
        {% assign fallback_image = blog_images[forloop.index0] | default: 'home-blog-v7-battery.webp' %}
        <li>
          <div class="blog-item">
            <a href="{{ article.url }}"><div class="blog_pic">{% if article.image %}{{ article.image | image_url: width: 1024 | image_tag: loading: 'lazy', alt: article.title }}{% else %}<img src="{{ fallback_image | asset_url }}" alt="{{ article.title | escape }}" loading="lazy" width="1024" height="628">{% endif %}</div></a>
            <div class="blog_text">
              <h5>{{ article.published_at | date: '%d %b %Y' }}</h5>
              <h3><a href="{{ article.url }}">{{ article.title }}</a></h3>
              <p>{{ article.excerpt_or_content | strip_html | truncate: 145 }}</p>
              <a href="{{ article.url }}" class="rd_more">Read More...</a>
            </div>
          </div>
        </li>
      {% else %}
        {% for image in blog_images %}
          <li>
            <div class="blog-item">
              <a href="/blogs/news"><div class="blog_pic"><img src="{{ image | asset_url }}" alt="{{ blog_titles[forloop.index0] | escape }}" loading="lazy" width="1024" height="628"></div></a>
              <div class="blog_text">
                <h5>{{ blog_dates[forloop.index0] }}</h5>
                <h3><a href="/blogs/news">{{ blog_titles[forloop.index0] }}</a></h3>
                <p>Helpful repair guidance and replacement advice for Dyson cordless vacuum owners.</p>
                <a href="/blogs/news" class="rd_more">Read More...</a>
              </div>
            </div>
          </li>
        {% endfor %}
      {% endfor %}
    </ul>
    <a class="rd_more btn3" href="{{ selected_blog.url | default: '/blogs/news' }}">view more</a>
  </div>
</section>

<section class="best_seller seo-copy">
  <div class="wrapper">
    <h2 class="title_center1">{{ section.settings.seo_heading_1 }}</h2>
    <div class="rte">{{ section.settings.seo_text_1 }}</div>
    <h2 class="title_center1">{{ section.settings.seo_heading_2 }}</h2>
    <div class="rte">{{ section.settings.seo_text_2 }}</div>
  </div>
</section>

{% schema %}
{
  "name": "Vacuum Wizard homepage",
  "settings": [
    {
      "type": "text",
      "id": "hero_label",
      "label": "Hero accessibility label",
      "default": "The independent Dyson hand held vacuum specialists"
    },
    {
      "type": "url",
      "id": "shop_link",
      "label": "Shop link"
    },
    {
      "type": "url",
      "id": "contact_link",
      "label": "Contact link"
    },
    {
      "type": "text",
      "id": "phone",
      "label": "Phone",
      "default": "03333 701 701"
    },
    {
      "type": "text",
      "id": "about_heading",
      "label": "About heading",
      "default": "The Vacuum Wizard - Dyson Vacuum Spare Parts Online Store"
    },
    {
      "type": "richtext",
      "id": "about_text",
      "label": "About text",
      "default": "<p>The Vacuum Wizard are independent specialists in Dyson hand held vacuum cleaners and spare parts. Our online store carries batteries, chargers, motors, filters and accessories for popular Dyson models.</p><p>We stock carefully selected parts and provide quick UK delivery for customers who want dependable repair solutions.</p>"
    },
    {
      "type": "url",
      "id": "about_link",
      "label": "About link"
    },
    {
      "type": "image_picker",
      "id": "about_image",
      "label": "About image"
    },
    {
      "type": "collection",
      "id": "best_sellers_collection",
      "label": "Best Sellers collection"
    },
    {
      "type": "range",
      "id": "best_sellers_limit",
      "label": "Best Sellers products to show",
      "min": 3,
      "max": 12,
      "step": 1,
      "default": 6
    },
    {
      "type": "collection",
      "id": "featured_collection",
      "label": "Featured Products collection"
    },
    {
      "type": "range",
      "id": "featured_limit",
      "label": "Featured Products to show",
      "min": 4,
      "max": 16,
      "step": 1,
      "default": 8
    },
    {
      "type": "collection",
      "id": "latest_collection",
      "label": "Latest Products collection"
    },
    {
      "type": "range",
      "id": "latest_limit",
      "label": "Latest Products to show",
      "min": 4,
      "max": 16,
      "step": 1,
      "default": 8
    },
    {
      "type": "collection",
      "id": "vacuum_collection",
      "label": "Vacuum Products collection"
    },
    {
      "type": "range",
      "id": "vacuum_limit",
      "label": "Vacuum Products to show",
      "min": 4,
      "max": 16,
      "step": 1,
      "default": 8
    },
    {
      "type": "collection",
      "id": "related_collection",
      "label": "Related Products collection"
    },
    {
      "type": "range",
      "id": "related_limit",
      "label": "Related Products to show",
      "min": 3,
      "max": 8,
      "step": 1,
      "default": 4
    },
    {
      "type": "url",
      "id": "reviews_link",
      "label": "Reviews link"
    },
    {
      "type": "blog",
      "id": "blog",
      "label": "Blog"
    },
    {
      "type": "text",
      "id": "seo_heading_1",
      "label": "SEO heading one",
      "default": "Dyson Cordless Vacuum Accessories Online"
    },
    {
      "type": "richtext",
      "id": "seo_text_1",
      "label": "SEO text one",
      "default": "<p>Dyson cordless vacuum accessories are available online for customers who need reliable replacement parts, batteries, chargers and tools for home cleaning.</p>"
    },
    {
      "type": "text",
      "id": "seo_heading_2",
      "label": "SEO heading two",
      "default": "Dyson Handheld Parts For Sale Online"
    },
    {
      "type": "richtext",
      "id": "seo_text_2",
      "label": "SEO text two",
      "default": "<p>The Vacuum Wizard supplies Dyson handheld spare parts for several popular cordless models, helping customers keep their machines working for longer.</p>"
    }
  ],
  "blocks": [
    {
      "type": "model",
      "name": "Dyson model",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Dyson V6"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Vacuum Wizard homepage",
      "blocks": [
        { "type": "model", "settings": { "title": "Dyson V6" } },
        { "type": "model", "settings": { "title": "Dyson V7" } },
        { "type": "model", "settings": { "title": "Dyson V8" } },
        { "type": "model", "settings": { "title": "Dyson V10" } },
        { "type": "model", "settings": { "title": "Dyson V11" } }
      ]
    }
  ]
}
{% endschema %}
