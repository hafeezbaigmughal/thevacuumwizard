<header class="site-header" data-section-id="{{ section.id }}">
  <div class="wrapper">
    <div class="top_header_left">
      <a href="tel:{{ section.settings.phone | remove: ' ' }}">
        <span aria-hidden="true">&#9742;</span>
        {{ section.settings.phone }}
      </a>
    </div>

    <div class="top_header_right">
      <ul class="accountLinkBox">
        <li><a href="{{ routes.account_login_url }}"><span>Log in</span></a></li>
        <li><a href="{{ routes.account_register_url }}"><span>Register</span></a></li>
        <li><a href="/pages/wishlist"><span>Wishlist</span></a></li>
        <li>
          <a class="cart-contents" href="{{ routes.cart_url }}" title="View your shopping cart">
            <span>Cart</span>
            <div class="ajaxloadrefresh">
              <strong>{{ cart.total_price | money }} ({{ cart.item_count }})</strong>
            </div>
          </a>
        </li>
      </ul>
    </div>
  </div>
</header>

<div class="topBar">
  <div class="wrapper">
    <div class="logo">
      <a href="{{ routes.root_url }}" aria-label="{{ shop.name | escape }}">
        {% if section.settings.logo != blank %}
          {{ section.settings.logo | image_url: width: 260 | image_tag: loading: 'eager', alt: shop.name }}
        {% else %}
          <img src="{{ 'home-vacuum-logo.png' | asset_url }}" alt="The Vacuum Wizard" width="212" height="107">
        {% endif %}
      </a>
    </div>

    <button class="nav-toggle" type="button" aria-expanded="false" aria-controls="HeaderMenu">
      <span></span><span></span><span></span>
    </button>

    <div id="header">
      <nav id="HeaderMenu" class="navMenu" aria-label="Main navigation">
        <ul class="menu">
          {% if section.settings.menu != blank and linklists[section.settings.menu].links.size > 0 %}
            {% for link in linklists[section.settings.menu].links %}
              <li class="{% if link.links.size > 0 %}menu-item-has-children{% endif %}{% if link.active %} current-menu-item{% endif %}">
                <a href="{{ link.url }}" {% if link.active %}aria-current="page"{% endif %}>{{ link.title }}</a>
                {% if link.links.size > 0 %}
                  <ul class="sub-menu">
                    {% for child_link in link.links %}
                      <li class="{% if child_link.active %}current-menu-item{% endif %}">
                        <a href="{{ child_link.url }}">{{ child_link.title }}</a>
                      </li>
                    {% endfor %}
                  </ul>
                {% endif %}
              </li>
            {% endfor %}
          {% else %}
            <li class="current-menu-item"><a href="{{ routes.root_url }}">Home</a></li>
            <li><a href="{{ routes.all_products_collection_url }}">Products</a></li>
            <li><a href="/pages/services">Services</a></li>
            <li><a href="/pages/about-us">About Us</a></li>
            <li><a href="/blogs/news">Blog</a></li>
            <li><a href="/pages/contact">Contact Us</a></li>
          {% endif %}
        </ul>
      </nav>
    </div>

    <form action="{{ routes.search_url }}" method="get" role="search">
      <div class="search-wrapper">
        <div class="input-holder">
          <input type="search" class="search-input" placeholder="Type to search" name="q">
          <button class="search-icon" type="submit" aria-label="Search"><span></span></button>
        </div>
      </div>
    </form>
  </div>
</div>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Main menu",
      "default": "main-menu"
    },
    {
      "type": "text",
      "id": "phone",
      "label": "Phone number",
      "default": "03333 701 701"
    }
  ]
}
{% endschema %}
