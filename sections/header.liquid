{% capture icon_account %}
  <svg class="topbar-link-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
    <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
    <circle cx="12" cy="7" r="4"></circle>
  </svg>
{% endcapture %}

{% capture icon_logout %}
  <svg class="topbar-link-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
    <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path>
    <path d="M16 17l5-5-5-5"></path>
    <path d="M21 12H9"></path>
  </svg>
{% endcapture %}

{% capture icon_register %}
  <svg class="topbar-link-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
    <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path>
    <circle cx="9" cy="7" r="4"></circle>
    <path d="M19 8v6"></path>
    <path d="M22 11h-6"></path>
  </svg>
{% endcapture %}

{% capture icon_wishlist %}
  <svg class="topbar-link-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
    <path d="M20.8 4.6a5.5 5.5 0 0 0-7.8 0L12 5.6l-1-1a5.5 5.5 0 0 0-7.8 7.8l1 1L12 21l7.8-7.6 1-1a5.5 5.5 0 0 0 0-7.8z"></path>
  </svg>
{% endcapture %}

{% capture icon_cart %}
  <svg class="topbar-link-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
    <circle cx="9" cy="21" r="1"></circle>
    <circle cx="20" cy="21" r="1"></circle>
    <path d="M1 1h4l2.7 13.4a2 2 0 0 0 2 1.6h8.7a2 2 0 0 0 2-1.6L22 6H6"></path>
  </svg>
{% endcapture %}

<header class="site-header" data-section-id="{{ section.id }}">
  <div class="wrapper">
    <div class="top_header_left">
      <a href="tel:{{ section.settings.phone | remove: ' ' }}">
        <span aria-hidden="true">&#9742;</span>
        {{ section.settings.phone }}
      </a>
    </div>

    <div class="top_header_right">
      <ul class="accountLinkBox">
        {% if shop.customer_accounts_enabled %}
          {% if customer %}
            <li><a href="{{ routes.account_url }}">{{ icon_account }}<span>My Account</span></a></li>
            <li><a href="{{ routes.account_logout_url }}">{{ icon_logout }}<span>Log Out</span></a></li>
          {% else %}
            <li><a href="{{ routes.account_url }}">{{ icon_account }}<span>My Account</span></a></li>
            <li><a href="{{ routes.account_register_url }}">{{ icon_register }}<span>Register</span></a></li>
          {% endif %}
        {% endif %}
        {% assign wishlist_url = section.settings.wishlist_page.url | default: '/pages/wishlist' %}
        <li><a href="{{ wishlist_url }}">{{ icon_wishlist }}<span>{{ section.settings.wishlist_label }}</span></a></li>
        <li>
          <a class="cart-contents" href="{{ routes.cart_url }}" title="View your shopping cart">
            {{ icon_cart }}
            <span>Cart</span>
          </a>
        </li>
        <li>
          <a class="cart-contents cart-amount" href="{{ routes.cart_url }}" title="View your shopping cart">
            <span class="ajaxloadrefresh"><strong>{{ cart.total_price | money }} ({{ cart.item_count }})</strong></span>
          </a>
        </li>
      </ul>
    </div>
  </div>
</header>

<div class="topBar">
  <div class="wrapper">
    <div class="logo">
      <a href="{{ routes.root_url }}" aria-label="{{ shop.name | escape }}">
        {% if section.settings.logo != blank %}
          {{ section.settings.logo | image_url: width: 260 | image_tag: loading: 'eager', alt: shop.name }}
        {% else %}
          <img src="{{ 'home-vacuum-logo.png' | asset_url }}" alt="{{ shop.name | escape }}" width="212" height="107">
        {% endif %}
      </a>
    </div>

    <button class="nav-toggle" type="button" aria-expanded="false" aria-controls="HeaderMenu">
      <span></span><span></span><span></span>
    </button>

    <div id="header">
      <nav id="HeaderMenu" class="navMenu" aria-label="Main navigation">
        <ul class="menu">
          {% if section.settings.menu != blank and linklists[section.settings.menu].links.size > 0 %}
            {% for link in linklists[section.settings.menu].links %}
              {% assign link_is_active = link.active | default: false %}
              {% if link.child_active %}{% assign link_is_active = true %}{% endif %}
              {% if request.page_type == 'article' and link.url == blog.url %}{% assign link_is_active = true %}{% endif %}
              <li class="{% if link.links.size > 0 %}menu-item-has-children{% endif %}{% if link_is_active %} current-menu-item{% endif %}">
                <a href="{{ link.url }}" {% if link_is_active %}aria-current="page"{% endif %}>{{ link.title }}</a>
                {% if link.links.size > 0 %}
                  <button class="submenu-toggle" type="button" aria-expanded="false" aria-label="Open {{ link.title | escape }} menu"></button>
                  <ul class="sub-menu">
                    {% for child_link in link.links %}
                      {% assign child_link_is_active = child_link.active | default: false %}
                      {% if child_link.child_active %}{% assign child_link_is_active = true %}{% endif %}
                      <li class="{% if child_link.links.size > 0 %}menu-item-has-children{% endif %}{% if child_link_is_active %}current-menu-item{% endif %}">
                        <a href="{{ child_link.url }}">{{ child_link.title }}</a>
                        {% if child_link.links.size > 0 %}
                          <button class="submenu-toggle" type="button" aria-expanded="false" aria-label="Open {{ child_link.title | escape }} menu"></button>
                          <ul class="sub-menu">
                            {% for grandchild_link in child_link.links %}
                              <li><a href="{{ grandchild_link.url }}">{{ grandchild_link.title }}</a></li>
                            {% endfor %}
                          </ul>
                        {% endif %}
                      </li>
                    {% endfor %}
                  </ul>
                {% endif %}
              </li>
            {% endfor %}
          {% else %}
            <li class="current-menu-item"><a href="{{ routes.root_url }}">Home</a></li>
            <li><a href="{{ routes.all_products_collection_url }}">Products</a></li>
          {% endif %}
        </ul>
      </nav>
    </div>

    <form action="{{ routes.search_url }}" method="get" role="search" class="header-search-form" data-header-search-form>
      <div class="search-wrapper" data-header-search>
        <div class="input-holder">
          <label class="visually-hidden" for="HeaderSearch">Search the store</label>
          <input id="HeaderSearch" type="search" class="search-input" placeholder="Search products" name="q" value="{{ search.terms | escape }}" autocomplete="off">
          <button
            class="search-icon"
            type="submit"
            aria-label="Open search"
            aria-controls="HeaderSearch"
            aria-expanded="false"
            data-header-search-button
          >
            <span aria-hidden="true"></span>
          </button>
        </div>
      </div>
    </form>
  </div>
</div>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Main menu",
      "default": "main-menu"
    },
    {
      "type": "text",
      "id": "phone",
      "label": "Phone number",
      "default": "03333 701 701"
    },
    {
      "type": "page",
      "id": "wishlist_page",
      "label": "Wishlist page",
      "info": "Leave blank unless a wishlist app or page is configured."
    },
    {
      "type": "text",
      "id": "wishlist_label",
      "label": "Wishlist label",
      "default": "Wishlist"
    }
  ]
}
{% endschema %}
