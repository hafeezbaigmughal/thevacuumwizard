<footer class="site-footer">
  <div class="footer_top">
    <div class="wrapper">
      <ul class="footer_dtls">
        <li class="footer-item">
          <div class="ftr_logo">
            <a href="{{ routes.root_url }}">
              {% if section.settings.footer_logo != blank %}
                {{ section.settings.footer_logo | image_url: width: 400 | image_tag: loading: 'lazy', alt: shop.name }}
              {% else %}
                <img src="{{ 'home-footer-award.png' | asset_url }}" alt="{{ shop.name | escape }}" width="200" height="200">
              {% endif %}
            </a>
          </div>
          {% if section.settings.trademark_text != blank %}<p>{{ section.settings.trademark_text }}</p>{% endif %}
          {% if section.settings.show_payment_icons %}
            <div class="footer-payment-icons" aria-label="Accepted payment methods">
              {% for type in shop.enabled_payment_types %}
                {{ type | payment_type_svg_tag }}
              {% endfor %}
            </div>
          {% endif %}
        </li>

        <li class="footer-item">
          <h3><span>Useful Links</span></h3>
          <ul class="menu">
            {% if section.settings.footer_menu != blank and linklists[section.settings.footer_menu].links.size > 0 %}
              {% for link in linklists[section.settings.footer_menu].links %}
                <li><a href="{{ link.url }}">{{ link.title }}</a></li>
              {% endfor %}
            {% else %}
              <li><a href="{{ routes.root_url }}">Home</a></li>
              <li><a href="{{ routes.all_products_collection_url }}">Products</a></li>
              <li><a href="{{ routes.cart_url }}">Cart</a></li>
            {% endif %}
          </ul>
        </li>

        <li class="footer-item">
          <h3><span>Get in Touch</span></h3>
          <div class="get_in_touch">
            <p>{{ section.settings.address }}</p>
            <p><a href="tel:{{ section.settings.phone | remove: ' ' }}">{{ section.settings.phone }}</a></p>
            <p><a href="mailto:{{ section.settings.email }}">{{ section.settings.email }}</a></p>
            <p><a href="mailto:{{ section.settings.sales_email }}">{{ section.settings.sales_email }}</a></p>
          </div>
          {%- liquid
            assign facebook_url = section.settings.facebook_url | default: settings.social_facebook_link
            assign twitter_url = section.settings.twitter_url | default: settings.social_x_link
            assign instagram_url = section.settings.instagram_url | default: settings.social_instagram_link
            assign linkedin_url = section.settings.linkedin_url | default: settings.social_linkedin_link
          -%}
          {% if facebook_url != blank or twitter_url != blank or instagram_url != blank or linkedin_url != blank %}
            <ul class="social_icons">
              {% if facebook_url != blank %}<li><a href="{{ facebook_url }}" aria-label="Facebook" rel="noopener" target="_blank">f</a></li>{% endif %}
              {% if twitter_url != blank %}<li><a href="{{ twitter_url }}" aria-label="X" rel="noopener" target="_blank">x</a></li>{% endif %}
              {% if instagram_url != blank %}<li><a href="{{ instagram_url }}" aria-label="Instagram" rel="noopener" target="_blank">ig</a></li>{% endif %}
              {% if linkedin_url != blank %}<li><a href="{{ linkedin_url }}" aria-label="LinkedIn" rel="noopener" target="_blank">in</a></li>{% endif %}
            </ul>
          {% endif %}
        </li>
      </ul>
    </div>

    <div class="footer_middl">
      <div class="wrapper">
        <ul>
          {% for policy in shop.policies %}
            {% if policy != blank %}<li><a href="{{ policy.url }}">{{ policy.title }}</a></li>{% endif %}
          {% endfor %}
        </ul>
      </div>
    </div>
  </div>

  <div class="footer_btm">
    <div class="wrapper">
      <p>The Vacuum Wizard is a Trading Name Of Bristolian Commerce Limited.<span>Registered in the UK</span></p>
      <p>&copy; {{ 'now' | date: '%Y' }} {{ shop.name | default: 'The Vacuum Wizard' }}</p>
      <p>Registration No: {{ section.settings.registration_number }}<span>VAT Number: {{ section.settings.vat_number }}</span></p>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "link_list",
      "id": "footer_menu",
      "label": "Footer menu"
    },
    {
      "type": "image_picker",
      "id": "footer_logo",
      "label": "Footer logo"
    },
    {
      "type": "textarea",
      "id": "trademark_text",
      "label": "Trademark text",
      "default": "Dyson and the Dyson logo are trademarks of Dyson Technology Limited."
    },
    {
      "type": "checkbox",
      "id": "show_payment_icons",
      "label": "Show enabled payment methods",
      "default": true
    },
    {
      "type": "text",
      "id": "address",
      "label": "Address",
      "default": "Trident Works, Marsh Lane, Temple Cloud, Bristol BS39 5AZ"
    },
    {
      "type": "text",
      "id": "phone",
      "label": "Phone",
      "default": "03333 701 701"
    },
    {
      "type": "text",
      "id": "email",
      "label": "Email",
      "default": "info@thevacuumwizard.co.uk"
    },
    {
      "type": "text",
      "id": "sales_email",
      "label": "Sales email",
      "default": "sales@thevacuumwizard.co.uk"
    },
    {
      "type": "text",
      "id": "registration_number",
      "label": "Registration number",
      "default": "9837814"
    },
    {
      "type": "text",
      "id": "vat_number",
      "label": "VAT number",
      "default": "GB9977813"
    },
    {
      "type": "url",
      "id": "facebook_url",
      "label": "Facebook URL"
    },
    {
      "type": "url",
      "id": "twitter_url",
      "label": "Twitter/X URL"
    },
    {
      "type": "url",
      "id": "instagram_url",
      "label": "Instagram URL"
    },
    {
      "type": "url",
      "id": "linkedin_url",
      "label": "LinkedIn URL"
    }
  ]
}
{% endschema %}
