<script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": {{ shop.name | json }},
    "url": {{ request.origin | append: routes.root_url | json }}
    {%- if shop.brand.logo != blank -%},
      "logo": {{ shop.brand.logo | image_url: width: 600 | prepend: 'https:' | json }}
    {%- endif -%}
    {%- assign social_links = settings.social_facebook_link | append: '|' | append: settings.social_instagram_link | append: '|' | append: settings.social_x_link | append: '|' | append: settings.social_youtube_link | append: '|' | append: settings.social_linkedin_link | split: '|' -%}
    {%- assign has_social = false -%}
    {%- for social_link in social_links -%}
      {%- if social_link != blank -%}{%- assign has_social = true -%}{%- endif -%}
    {%- endfor -%}
    {%- if has_social -%},
      "sameAs": [
        {%- assign social_separator = '' -%}
        {%- for social_link in social_links -%}
          {%- if social_link != blank -%}{{ social_separator }}{{ social_link | json }}{%- assign social_separator = ',' -%}{%- endif -%}
        {%- endfor -%}
      ]
    {%- endif -%}
  }
</script>

{% if request.page_type == 'product' %}
  <script type="application/ld+json">
    {{ product | structured_data }}
  </script>
{% elsif request.page_type == 'article' %}
  <script type="application/ld+json">
    {{ article | structured_data }}
  </script>
{% endif %}

{% unless request.page_type == 'index' or request.page_type == '404' %}
  {%- liquid
    assign breadcrumb_parent_name = blank
    assign breadcrumb_parent_url = blank
    case request.page_type
      when 'product'
        assign breadcrumb_parent_name = product.collections.first.title
        assign breadcrumb_parent_url = product.collections.first.url
      when 'article'
        assign breadcrumb_parent_name = blog.title
        assign breadcrumb_parent_url = blog.url
      when 'collection'
        assign breadcrumb_parent_name = 'Collections'
        assign breadcrumb_parent_url = routes.collections_url
    endcase
  -%}
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Home",
          "item": {{ request.origin | append: routes.root_url | json }}
        }
        {%- if breadcrumb_parent_name != blank -%},
          {
            "@type": "ListItem",
            "position": 2,
            "name": {{ breadcrumb_parent_name | json }},
            "item": {{ request.origin | append: breadcrumb_parent_url | json }}
          }
        {%- endif -%},
        {
          "@type": "ListItem",
          "position": {% if breadcrumb_parent_name != blank %}3{% else %}2{% endif %},
          "name": {{ page_title | json }},
          "item": {{ canonical_url | json }}
        }
      ]
    }
  </script>
{% endunless %}
