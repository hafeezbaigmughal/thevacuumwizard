{%- liquid
  assign product_link = product.url
  assign product_title = product.title
  assign media_class = media_class | default: 'best_product_details_pic'
  assign text_class = text_class | default: 'best_product_details_text'
  assign wrapper_class = wrapper_class | default: ''
-%}

{% if product != blank %}<li>
  {% if wrapper_class != blank %}<div class="{{ wrapper_class }}">{% endif %}
    <div class="{{ media_class }}">
      <a href="{{ product_link }}" aria-label="{{ product_title | escape }}">
        {% if product.featured_image %}
          {{ product.featured_image | image_url: width: 640 | image_tag: loading: 'lazy', widths: '240, 360, 520, 640', sizes: '(max-width: 640px) 50vw, 280px', alt: product.featured_image.alt | default: product_title }}
        {% else %}
          {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
        {% endif %}
      </a>
      <div class="over_lay">
        <a class="button" href="{{ product_link }}">View Product</a>
      </div>
    </div>

    <div class="{{ text_class }}">
      <div class="book_name">
        <a href="{{ product_link }}">{{ product_title }}</a>
      </div>

      <h3 class="prize">
        {{ product.price | money }}
        {% if product.compare_at_price > product.price %}
          <span>{{ product.compare_at_price | money }}</span>
        {% endif %}
      </h3>

      <div class="add_waslist">
        {% if product.available and product.has_only_default_variant %}
          <form method="post" action="{{ routes.cart_add_url }}">
            <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
            <button class="button product_type_simple add_to_cart_button" type="submit" aria-label="Add {{ product_title | escape }} to cart">
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d="M7 18c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2Zm10 0c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2ZM6.2 6l.9 5.3c.2 1 1 1.7 2 1.7h7.4c.9 0 1.7-.6 1.9-1.5L20 6H6.2ZM5.8 4H21c.6 0 1 .5.9 1.1l-1.6 6.9c-.4 1.8-2 3-3.8 3H9.1c-2 0-3.6-1.4-4-3.3L3.9 4.9 2 4.5V3h2.6c.6 0 1.1.4 1.2 1Z"/>
              </svg>
            </button>
          </form>
        {% else %}
          <a class="button product_type_simple add_to_cart_button" href="{{ product_link }}" aria-label="{% if product.available %}Choose options for{% else %}View{% endif %} {{ product_title | escape }}">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="M7 18c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2Zm10 0c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2ZM6.2 6l.9 5.3c.2 1 1 1.7 2 1.7h7.4c.9 0 1.7-.6 1.9-1.5L20 6H6.2ZM5.8 4H21c.6 0 1 .5.9 1.1l-1.6 6.9c-.4 1.8-2 3-3.8 3H9.1c-2 0-3.6-1.4-4-3.3L3.9 4.9 2 4.5V3h2.6c.6 0 1.1.4 1.2 1Z"/>
            </svg>
          </a>
        {% endif %}
      </div>
    </div>
  {% if wrapper_class != blank %}</div>{% endif %}
</li>{% endif %}
