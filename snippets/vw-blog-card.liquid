{% if article != blank %}
  {% assign article_alt = article.image.alt | default: article.title %}
  <article class="blog-card">
    <a class="blog-card__image" href="{{ article.url }}">
      {% if article.image %}
        {{ article.image | image_url: width: 720 | image_tag: loading: 'lazy', widths: '360, 540, 720', sizes: '(max-width: 640px) 100vw, 360px', alt: article_alt }}
      {% else %}
        {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
      {% endif %}
    </a>
    <div class="blog-card__content">
      <time datetime="{{ article.published_at | date: '%Y-%m-%d' }}">{{ article.published_at | date: '%d %b %Y' }}</time>
      <h2><a href="{{ article.url }}">{{ article.title }}</a></h2>
      <p>{{ article.excerpt_or_content | strip_html | truncate: 120 }}</p>
      <a class="text-link" href="{{ article.url }}">Read More...</a>
    </div>
  </article>
{% endif %}
