{%- liquid
  assign fallback_image = fallback_image | default: 'vacuum-wizard-blog-1.png'
  assign fallback_title = fallback_title | default: 'How to Replace Dyson V7 Battery?'
  assign fallback_excerpt = fallback_excerpt | default: 'Helpful repair guidance and replacement advice for Dyson cordless vacuum owners.'
  assign fallback_date = fallback_date | default: '03 Jun 2026'
  assign article_alt = article.image.alt | default: article.title
-%}

<article class="blog-card">
  <a class="blog-card__image" href="{{ article.url | default: '#' }}">
    {% if article != blank and article.image %}
      {{ article.image | image_url: width: 720 | image_tag: loading: 'lazy', alt: article_alt }}
    {% else %}
      <img src="{{ fallback_image | asset_url }}" alt="{{ fallback_title | escape }}" loading="lazy">
    {% endif %}
  </a>
  <div class="blog-card__content">
    <time>{{ article.published_at | date: '%d %b %Y' | default: fallback_date }}</time>
    <h3><a href="{{ article.url | default: '#' }}">{{ article.title | default: fallback_title }}</a></h3>
    <p>{{ article.excerpt_or_content | strip_html | truncate: 120 | default: fallback_excerpt }}</p>
    <a class="text-link" href="{{ article.url | default: '#' }}">Read More...</a>
  </div>
</article>
