{%- liquid
  assign meta_title = page_title
  unless meta_title contains shop.name
    assign meta_title = meta_title | append: ' | ' | append: shop.name
  endunless
  if current_tags
    assign tag_names = current_tags | join: ', '
    assign meta_title = tag_names | append: ' - ' | append: meta_title
  endif
  if current_page != 1
    assign meta_title = meta_title | append: ' - Page ' | append: current_page
  endif

  assign meta_description = page_description | default: shop.description | strip_html | strip_newlines | truncate: 320
  assign og_type = 'website'
  if request.page_type == 'product'
    assign og_type = 'product'
  elsif request.page_type == 'article'
    assign og_type = 'article'
  endif

  assign share_image = page_image
  if request.page_type == 'product' and product.featured_image
    assign share_image = product.featured_image
  elsif request.page_type == 'article' and article.image
    assign share_image = article.image
  elsif request.page_type == 'collection' and collection.image
    assign share_image = collection.image
  endif
-%}
<title>{{ meta_title | escape }}</title>
{% if meta_description != blank %}
  <meta name="description" content="{{ meta_description | escape }}">
{% endif %}
<link rel="canonical" href="{{ canonical_url }}">
{% if request.page_type == 'search' or request.page_type == 'cart' or request.page_type == '404' or request.page_type contains 'customers/' %}
  <meta name="robots" content="noindex,follow">
{% endif %}

<meta property="og:site_name" content="{{ shop.name | escape }}">
<meta property="og:url" content="{{ canonical_url }}">
<meta property="og:title" content="{{ meta_title | escape }}">
<meta property="og:type" content="{{ og_type }}">
{% if meta_description != blank %}
  <meta property="og:description" content="{{ meta_description | escape }}">
{% endif %}
{% if share_image != blank %}
  <meta property="og:image" content="https:{{ share_image | image_url: width: 1200 }}">
  <meta property="og:image:secure_url" content="https:{{ share_image | image_url: width: 1200 }}">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:alt" content="{{ share_image.alt | default: page_title | escape }}">
{% endif %}
{% if request.page_type == 'product' %}
  <meta property="product:price:amount" content="{{ product.selected_or_first_available_variant.price | money_without_currency | strip_html }}">
  <meta property="product:price:currency" content="{{ cart.currency.iso_code }}">
{% endif %}

<meta name="twitter:card" content="{% if share_image != blank %}summary_large_image{% else %}summary{% endif %}">
<meta name="twitter:title" content="{{ meta_title | escape }}">
{% if meta_description != blank %}
  <meta name="twitter:description" content="{{ meta_description | escape }}">
{% endif %}
